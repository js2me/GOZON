{
  "name": "gozon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --clear-screen=false src/server/index.tsx",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/server/index.tsx --outDir dist/server --emptyOutDir=false --minify esbuild",
    "build": "pnpm build:client && pnpm build:server && tsc --noEmit",
    "prod": "pnpm start",
    "lint:check": "pnpm exec biome check --write --no-errors-on-unmatched --files-ignore-unknown=true src",
    "check": "pnpm run lint:check && tsc --noEmit",
    "start": "NODE_ENV=production pnpm build && NODE_ENV=production node dist/server/index.js",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "express": "^4.21.2",
    "lucide-react": "^1.8.0",
    "mobx": "^6.13.7",
    "mobx-location-history": "9.3.1",
    "mobx-react-lite": "^4.1.1",
    "mobx-route": "^0.29.1",
    "mobx-view-model": "^10.2.0",
    "mobx-view-model-react": "^10.2.0",
    "mobx-web-api": "^1.13.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-virtuoso": "^4.15.0",
    "tsx": "^4.21.0",
    "yummies": "^7.19.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tailwindcss/cli": "^4.1.14",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^5.0.0",
    "esbuild": "^0.25.10",
    "js2me-biome-config": "^1.1.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  }
}
