{
  "name": "gozon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --clear-screen=false src/server/index.tsx",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/server/index.tsx --outDir dist/server --emptyOutDir=false --minify esbuild",
    "build": "pnpm build:client && pnpm build:server && tsc --noEmit",
    "prod": "pnpm start",
    "lint:check": "pnpm exec biome check --write --no-errors-on-unmatched --files-ignore-unknown=true src",
    "check": "pnpm run lint:check && tsc --noEmit",
    "start": "NODE_ENV=production pnpm build && NODE_ENV=production node dist/server/index.js",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^10.5.0",
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "dotenv": "^17.4.2",
    "es-toolkit": "^1.48.1",
    "express": "^5.2.1",
    "lucide-react": "^1.21.0",
    "mobx": "^6.16.1",
    "mobx-location-history": "9.4.0",
    "mobx-react-lite": "^4.1.1",
    "mobx-route": "^1.2.0",
    "mobx-view-model": "^10.2.3",
    "mobx-view-model-react": "^10.3.0",
    "mobx-view-model-vite-plugin": "^1.4.3",
    "mobx-web-api": "^1.14.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-virtuoso": "^4.18.8",
    "tsx": "^4.22.4",
    "yummies": "^7.20.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "js2me-biome-config": "^1.1.0",
    "jsdom": "^29.1.1",
    "selfsigned": "^5.5.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
