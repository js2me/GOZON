{
  "name": "gozon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --clear-screen=false src/server/index.tsx",
    "build:styles": "tailwindcss -i src/app/styles.css -o dist/styles.css",
    "build:styles:prod": "pnpm build:styles --minify",
    "build:client": "esbuild src/client.tsx --bundle --format=esm --platform=browser --splitting --outdir=dist --entry-names=[name] --chunk-names=chunks/[name]-[hash]",
    "build:client:prod": "pnpm build:client --minify --target=es2020",
    "build": "pnpm build:styles && pnpm build:client && tsc --noEmit",
    "prod": "pnpm start",
    "lint:check": "pnpm exec biome check --write --no-errors-on-unmatched --files-ignore-unknown=true src",
    "check": "pnpm run lint:check && tsc --noEmit",
    "start": "NODE_ENV=production pnpm build:styles:prod && pnpm build:client:prod && tsx src/server/index.tsx",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "express": "^4.21.2",
    "lucide-react": "^1.8.0",
    "mobx": "^6.13.7",
    "mobx-location-history": "9.3.1",
    "mobx-react-lite": "^4.1.1",
    "mobx-view-model": "^10.0.4",
    "mobx-view-model-react": "^10.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-virtuoso": "^4.15.0",
    "tsx": "^4.21.0",
    "yummies": "^7.19.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tailwindcss/cli": "^4.1.14",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^5.0.0",
    "esbuild": "^0.25.10",
    "js2me-biome-config": "^1.1.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  }
}
